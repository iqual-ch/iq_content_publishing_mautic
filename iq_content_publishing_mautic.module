<?php

/**
 * @file
 * Mautic email integration for the Content Publishing framework.
 */

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;

/**
 * Implements hook_entity_operation().
 *
 * Adds Mautic-specific operations (Fetch Segments, Fetch Emails)
 * to Mautic platform config entities on the admin list.
 */
function iq_content_publishing_mautic_entity_operation(EntityInterface $entity): array {
  $operations = [];

  if ($entity->getEntityTypeId() !== 'publishing_platform') {
    return $operations;
  }

  /** @var \Drupal\iq_content_publishing\Entity\PublishingPlatformConfigInterface $entity */
  if ($entity->getPluginId() !== 'mautic') {
    return $operations;
  }

  $credentials = $entity->getCredentials();

  if (!empty($credentials['connection_id'])) {
    $operations['mautic_fetch_segments'] = [
      'title' => t('Fetch Segments'),
      'url' => Url::fromRoute('iq_content_publishing_mautic.fetch_segments', [
        'platform_config' => $entity->id(),
      ]),
      'weight' => 50,
    ];

    $operations['mautic_fetch_emails'] = [
      'title' => t('Fetch Emails'),
      'url' => Url::fromRoute('iq_content_publishing_mautic.fetch_emails', [
        'platform_config' => $entity->id(),
      ]),
      'weight' => 51,
    ];

    $operations['mautic_fetch_templates'] = [
      'title' => t('Fetch Templates'),
      'url' => Url::fromRoute('iq_content_publishing_mautic.fetch_templates', [
        'platform_config' => $entity->id(),
      ]),
      'weight' => 52,
    ];
  }

  return $operations;
}

/**
 * Implements hook_form_alter() for the publishing review form.
 *
 * Merges the Mautic email template with the AI-generated content snippet
 * before displaying in the review form, so the user sees and can edit the
 * complete email HTML (template + AI content merged together).
 */
function iq_content_publishing_mautic_form_iq_content_publishing_review_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $generatedContents = $form_state->get('generated_contents') ?? [];
  if (empty($generatedContents)) {
    return;
  }

  $platformStorage = \Drupal::entityTypeManager()->getStorage('publishing_platform');

  foreach ($generatedContents as $entryKey => $data) {
    $platformId = $data['platform_id'] ?? '';
    if (empty($platformId)) {
      continue;
    }

    /** @var \Drupal\iq_content_publishing\Entity\PublishingPlatformConfigInterface|null $platform */
    $platform = $platformStorage->load($platformId);
    if (!$platform || $platform->getPluginId() !== 'mautic') {
      continue;
    }

    $settings = $platform->getPluginSettings();
    $templateHtml = _iq_content_publishing_mautic_load_template_html($settings);

    if (empty($templateHtml) || !str_contains($templateHtml, '{ai_content}')) {
      continue;
    }

    // Get the AI-generated html_body snippet.
    $snippet = $data['fields']['html_body'] ?? '';
    if (empty($snippet)) {
      continue;
    }

    // Merge template with the AI-generated content.
    $mergedHtml = str_replace('{ai_content}', $snippet, $templateHtml);

    // Update the form field's default value to the merged HTML.
    if (isset($form['platforms'][$entryKey]['fields']['html_body'])) {
      $form['platforms'][$entryKey]['fields']['html_body']['#default_value'] = $mergedHtml;
    }
  }
}

/**
 * Loads Mautic template HTML from file storage or config fallback.
 *
 * @param array $settings
 *   The platform plugin settings.
 *
 * @return string
 *   The template HTML, or empty string if unavailable.
 */
function _iq_content_publishing_mautic_load_template_html(array $settings): string {
  if (!empty($settings['template_file_uri'])) {
    $contents = @file_get_contents($settings['template_file_uri']);
    if ($contents !== FALSE) {
      return $contents;
    }
  }

  if (!empty($settings['template_html'])) {
    return is_array($settings['template_html'])
      ? ($settings['template_html']['value'] ?? '')
      : (string) $settings['template_html'];
  }

  return '';
}
